	},
	"repository": "Crysthamus/tree-sitter-wasm",
	"author": "Crysthamus",
	"license": "MIT",
	"type": "module",
	"main": "index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.js",
			"default": "./index.js"
		},
		"./manifest.json": "./manifest.json",
		"./*": "./out/*"
	},
	"files": [
		"out",
		"index.js",
		"index.d.ts",
		"manifest.json"
	],
	"scripts": {
		"build": "node build.js",
		"test": "echo \"WASM binaries verified during build.\" && exit 0"
	},
