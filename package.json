		"incremental",
		"parsing",
		"parser",
		"ts-wasms",
		"webassembly",
		"syntax-tree",
		"tree-sitter",
		"wasm"
	],
	"homepage": "https://github.com/Crysthamus/tree-sitter-wasm#readme",
